<%- include("partials/header") %>

<section class="profile-banner">
  <div class="profile-avatar"><%= ((config.botIdentity && config.botIdentity.name) || config.brandName || "B").slice(0, 1).toUpperCase() %></div>
  <div>
    <p class="eyebrow">Personalizacao do bot</p>
    <h2><%= (config.botIdentity && config.botIdentity.name) || "Baile da Selva" %></h2>
    <p><%= (config.botIdentity && config.botIdentity.tagline) || "Painel privado do Baile da Selva, sem planos ou assinaturas." %></p>
    <div class="chip-row">
      <span class="chip">Prefixo <strong><%= config.botIdentity && config.botIdentity.prefix ? config.botIdentity.prefix : "!" %></strong></span>
      <span class="chip">Idioma <strong><%= config.botIdentity && config.botIdentity.language ? config.botIdentity.language : "pt-BR" %></strong></span>
      <span class="chip">Uso privado</span>
    </div>
  </div>
</section>

<section class="stat-grid">
  <article class="stat-card">
    <span>Tickets abertos</span>
    <strong><%= stats.ticketsOpen %></strong>
  </article>
  <article class="stat-card">
    <span>Tickets fechados</span>
    <strong><%= stats.ticketsClosed %></strong>
  </article>
  <article class="stat-card">
    <span>Pedidos internos</span>
    <strong><%= stats.ordersOpen %></strong>
  </article>
  <article class="stat-card">
    <span>Modulos ativos</span>
    <strong><%= stats.modulesActive %></strong>
  </article>
</section>

<section class="panel wide">
  <div class="panel-head">
    <div>
      <p class="eyebrow">Modulos</p>
      <h2>Central Baile da Selva</h2>
    </div>
    <form method="post" action="/modules/reset-all">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="secondary-button" data-confirm="Desativar todas as funcoes?">Desativar tudo</button>
    </form>
  </div>
  <div class="module-grid">
    <% (categoryCatalog || []).forEach((category) => { %>
      <% const activeCount = (category.items || []).filter((item) => config.modules && config.modules[item.key] && config.modules[item.key].enabled).length; %>
      <a class="module-tile <%= activeCount ? 'enabled' : '' %>" href="/modules/<%= category.items[0].key %>">
        <span class="module-icon"><%= category.icon %></span>
        <span>
          <strong><%= category.title %></strong>
          <small><%= activeCount %> ativos / <%= category.items.length %> funcoes</small>
        </span>
      </a>
    <% }) %>
  </div>
</section>

<section class="grid-two">
  <div class="panel">
    <div class="panel-head">
      <h2>Controle rapido</h2>
    </div>
    <form action="/bot/register" method="post" class="inline-actions">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="secondary-button">Registrar comandos</button>
      <a class="secondary-link" href="/tickets">Configurar tickets</a>
      <a class="secondary-link" href="/store">Configurar loja interna</a>
    </form>
    <dl class="detail-list">
      <div><dt>Servidor</dt><dd><%= config.guildId || "Nao definido" %></dd></div>
      <div><dt>Aplicacao</dt><dd><%= config.clientId || "Nao definido" %></dd></div>
      <div><dt>URL do painel</dt><dd><%= config.panelBaseUrl %></dd></div>
    </dl>
  </div>

  <div class="panel">
    <div class="panel-head">
      <h2>Ultimos eventos</h2>
      <a href="/activity">Ver tudo</a>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr><th>Tipo</th><th>Data</th></tr>
        </thead>
        <tbody>
          <% events.forEach((event) => { %>
            <tr>
              <td><%= event.type %></td>
              <td><%= formatDate(event.createdAt) %></td>
            </tr>
          <% }) %>
          <% if (!events.length) { %>
            <tr><td colspan="2">Sem eventos ainda.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="grid-two">
  <div class="panel">
    <div class="panel-head">
      <h2>Tickets recentes</h2>
      <a href="/tickets">Abrir</a>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Usuario</th><th>Status</th><th>Criado</th></tr></thead>
        <tbody>
          <% tickets.forEach((ticket) => { %>
            <tr>
              <td><%= ticket.userTag %></td>
              <td><span class="badge"><%= ticket.status %></span></td>
              <td><%= formatDate(ticket.createdAt) %></td>
            </tr>
          <% }) %>
          <% if (!tickets.length) { %>
            <tr><td colspan="3">Nenhum ticket registrado.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="panel">
    <div class="panel-head">
      <h2>Pedidos internos recentes</h2>
      <a href="/store">Abrir</a>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Produto</th><th>Status</th><th>Criado</th></tr></thead>
        <tbody>
          <% orders.forEach((order) => { %>
            <tr>
              <td><%= order.productName %></td>
              <td><span class="badge"><%= order.status %></span></td>
              <td><%= formatDate(order.createdAt) %></td>
            </tr>
          <% }) %>
          <% if (!orders.length) { %>
            <tr><td colspan="3">Nenhum pedido registrado.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
