<%- include("partials/header") %>

<section class="profile-banner compact-banner">
  <div class="profile-avatar"><%= ((config.botIdentity && config.botIdentity.name) || config.brandName || "B").slice(0, 1).toUpperCase() %></div>
  <div>
    <p class="eyebrow">Perfil do bot</p>
    <h2><%= (config.botIdentity && config.botIdentity.name) || "Baile da Selva" %></h2>
    <p>Ajuste a identidade visual e os dados principais usados pelo painel e pelos comandos.</p>
  </div>
</section>

<section class="panel wide">
  <div class="panel-head">
    <div>
      <p class="eyebrow">Bot</p>
      <h2>Identidade e acesso</h2>
    </div>
  </div>
  <form method="post" action="/settings" class="form-grid">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>
      Nome do projeto
      <input name="brandName" value="<%= config.brandName %>" required>
    </label>
    <label>
      Nome do bot
      <input name="botName" value="<%= config.botIdentity && config.botIdentity.name ? config.botIdentity.name : config.brandName %>" required>
    </label>
    <label>
      Prefixo
      <input name="prefix" value="<%= config.botIdentity && config.botIdentity.prefix ? config.botIdentity.prefix : 'bs!' %>" maxlength="8">
    </label>
    <label>
      Idioma
      <input name="language" value="<%= config.botIdentity && config.botIdentity.language ? config.botIdentity.language : 'pt-BR' %>">
    </label>
    <label>
      Cor principal
      <input type="color" name="accentColor" value="<%= config.accentColor %>">
    </label>
    <label>
      Avatar por URL
      <input name="avatarUrl" value="<%= config.botIdentity && config.botIdentity.avatarUrl ? config.botIdentity.avatarUrl : '' %>" placeholder="https://...">
    </label>
    <label>
      Banner por URL
      <input name="bannerUrl" value="<%= config.botIdentity && config.botIdentity.bannerUrl ? config.botIdentity.bannerUrl : '' %>" placeholder="https://...">
    </label>
    <label>
      ID do servidor
      <input name="guildId" value="<%= config.guildId %>" placeholder="123456789012345678">
    </label>
    <label>
      ID da aplicacao
      <input name="clientId" value="<%= config.clientId %>" placeholder="123456789012345678">
    </label>
    <label>
      URL do painel
      <input name="panelBaseUrl" value="<%= config.panelBaseUrl %>" placeholder="http://127.0.0.1:3000">
    </label>
    <label>
      Canal de logs gerais
      <input name="modLogChannelId" value="<%= config.modLogChannelId %>" placeholder="ID do canal">
    </label>
    <label class="full">
      Texto curto do painel
      <textarea name="tagline" rows="3"><%= config.botIdentity && config.botIdentity.tagline ? config.botIdentity.tagline : '' %></textarea>
    </label>
    <label class="full">
      Cargos da equipe
      <textarea name="staffRoleIds" rows="3" placeholder="Um ID por linha"><%= (config.staffRoleIds || []).join("\n") %></textarea>
    </label>
    <div class="form-actions full">
      <button type="submit" class="primary-button">Salvar geral</button>
    </div>
  </form>
</section>

<%- include("partials/footer") %>
