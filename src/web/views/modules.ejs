<%- include("partials/header") %>

<section class="module-hero">
  <div class="module-icon"><%= panelModule.icon %></div>
  <div>
    <p class="eyebrow"><%= panelModule.group %></p>
    <h2><%= panelModule.title %></h2>
    <p><%= panelModule.description %></p>
  </div>
  <span class="module-state <%= moduleConfig.enabled ? 'on' : 'off' %>">
    <%= moduleConfig.enabled ? "Ativo" : "Desativado" %>
  </span>
</section>

<section class="module-config">
  <form method="post" action="/modules/<%= panelModule.key %>" class="module-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="config-card-grid">
      <% (panelModule.cards || []).forEach((card) => { %>
        <article class="config-card">
          <div class="config-card-head">
            <span class="card-icon"><%= card.icon || panelModule.icon %></span>
            <div>
              <h2><%= card.title %></h2>
              <p><%= card.description %></p>
            </div>
          </div>

          <div class="card-fields">
            <% (card.fields || []).forEach((field) => { %>
              <% const value = moduleConfig[field.name]; %>
              <% if (field.type === "checkbox") { %>
                <label class="switch card-switch">
                  <input type="checkbox" name="<%= field.name %>" <%= value ? "checked" : "" %>>
                  <span><%= field.label %></span>
                </label>
              <% } else if (field.type === "textarea") { %>
                <label class="full">
                  <%= field.label %>
                  <textarea name="<%= field.name %>" rows="4" placeholder="<%= field.placeholder || '' %>"><%= Array.isArray(value) ? value.join("\n") : (value || "") %></textarea>
                </label>
              <% } else { %>
                <label>
                  <%= field.label %>
                  <input
                    type="<%= field.type || 'text' %>"
                    name="<%= field.name %>"
                    value="<%= value || '' %>"
                    placeholder="<%= field.placeholder || '' %>"
                    <% if (field.min !== undefined) { %>min="<%= field.min %>"<% } %>
                  >
                </label>
              <% } %>
            <% }) %>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="module-actions">
      <button type="submit" class="primary-button">Salvar alteracoes</button>
      <button type="submit" class="secondary-button" form="reset-module">Redefinir tudo</button>
    </div>
  </form>

  <form id="reset-module" method="post" action="/modules/<%= panelModule.key %>/reset">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  </form>
</section>

<section class="panel wide quiet-panel">
  <div class="panel-head">
    <h2>Comeca desligado</h2>
  </div>
  <p class="muted">
    Todas as funcoes novas entram desativadas. Voce ativa so o que quiser usar no seu bot.
  </p>
</section>

<section class="panel wide quiet-panel">
  <div class="panel-head">
    <h2>Sem pagamentos</h2>
  </div>
  <p class="muted">
    Este painel e privado do Baile da Selva. Nao tem plano, assinatura ou cobranca para usar estas configuracoes.
  </p>
</section>

<%- include("partials/footer") %>
