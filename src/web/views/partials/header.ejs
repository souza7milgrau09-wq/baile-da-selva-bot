<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> | <%= config ? config.brandName : "Baile da Selva" %></title>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body>
  <div class="shell">
    <aside class="sidebar">
      <a class="brand" href="/">
        <span class="brand-mark"></span>
        <span>
          <strong>Baile da Selva</strong>
          <small>Painel privado</small>
        </span>
      </a>
      <div class="bot-card">
        <span class="bot-avatar"><%= ((config.botIdentity && config.botIdentity.name) || config.brandName || "B").slice(0, 1).toUpperCase() %></span>
        <span>
          <strong><%= (config.botIdentity && config.botIdentity.name) || config.brandName || "Baile da Selva" %></strong>
          <small><%= config.botIdentity && config.botIdentity.prefix ? config.botIdentity.prefix : "!" %> comandos</small>
        </span>
      </div>
      <label class="nav-search">
        <span>Buscar configuracao</span>
        <input data-nav-search placeholder="Buscar configuracao...">
      </label>
      <nav class="nav" aria-label="Menu">
        <p class="nav-group">Configuracoes</p>
        <a data-nav-item class="<%= active === 'dashboard' ? 'active' : '' %>" href="/"><span class="nav-icon">IN</span> Inicio</a>
        <a data-nav-item class="<%= active === 'settings' ? 'active' : '' %>" href="/settings"><span class="nav-icon">ID</span> Identidade geral</a>
        <a data-nav-item class="<%= active === 'commands' ? 'active' : '' %>" href="/commands"><span class="nav-icon">CM</span> Comandos por prefixo</a>
        <% (categoryCatalog || []).forEach((category) => { %>
          <% const categoryOpen = (category.items || []).some((item) => active === item.key); %>
          <div class="nav-section <%= categoryOpen ? 'open' : '' %>" data-nav-section>
            <a data-nav-item class="nav-category <%= categoryOpen ? 'active' : '' %>" href="/modules/<%= category.items[0].key %>">
              <span class="nav-icon"><%= category.icon %></span>
              <span><%= category.title %></span>
              <small><%= category.items.length %></small>
            </a>
            <div class="nav-sublist">
              <% category.items.forEach((item) => { %>
                <a data-nav-item class="nav-subitem <%= active === item.key ? 'active' : '' %>" href="/modules/<%= item.key %>"><%= item.title %></a>
              <% }) %>
            </div>
          </div>
        <% }) %>
        <p class="nav-group">Operacao</p>
        <a data-nav-item class="<%= active === 'tickets' ? 'active' : '' %>" href="/tickets"><span class="nav-icon">TK</span> Ticket</a>
        <a data-nav-item class="<%= active === 'forms' ? 'active' : '' %>" href="/forms"><span class="nav-icon">FM</span> Formularios</a>
        <a data-nav-item class="<%= active === 'store' ? 'active' : '' %>" href="/store"><span class="nav-icon">LJ</span> Loja interna</a>
        <a data-nav-item class="<%= active === 'welcome' ? 'active' : '' %>" href="/welcome"><span class="nav-icon">BV</span> Boas-vindas</a>
        <a data-nav-item class="<%= active === 'activity' ? 'active' : '' %>" href="/activity"><span class="nav-icon">RG</span> Registros</a>
      </nav>
      <form action="/logout" method="post" class="logout">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="ghost-button">Sair</button>
      </form>
    </aside>
    <main class="main">
      <header class="topbar">
        <div>
          <p class="eyebrow">Configuracoes / <%= title %></p>
          <h1><%= title %></h1>
        </div>
        <div class="status-pill <%= botStatus.ready ? 'is-online' : 'is-offline' %>">
          <span></span>
          <%= botStatus.ready ? botStatus.user : (botStatus.lastError || "Aguardando token") %>
        </div>
      </header>
      <% if (flash) { %>
        <div class="flash <%= flash.type %>"><%= flash.message %></div>
      <% } %>
